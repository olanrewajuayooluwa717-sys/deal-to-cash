# Xero OAuth (create app at https://developer.xero.com/app/manage)
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=http://localhost:3000/api/xero/callback

# OpenAI — optional for demo; without it, rule-based fallback mapping is used
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# App URL (used for OAuth redirect after connect)
NEXT_PUBLIC_APP_URL=http://localhost:3000
